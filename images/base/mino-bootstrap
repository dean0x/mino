#!/usr/bin/env bash
# Bootstrap developer home directory from /etc/skel/.
# Runs once per home volume (idempotent via marker file).
# Errors are non-fatal — container starts even if bootstrap fails.
MARKER="$HOME/.mino-bootstrapped"
IMAGE_VERSION_FILE="/etc/mino-base-version"
IMAGE_VERSION=$(cat "$IMAGE_VERSION_FILE" 2>/dev/null || echo "unknown")

# Refresh CLI tool symlinks from /opt/mino-tools/ into ~/.local/bin/.
# Non-destructive: never overwrites a real file (only missing or existing symlinks).
refresh_tool_symlinks() {
    if [ -d "/opt/mino-tools" ]; then
        mkdir -p "$HOME/.local/bin" 2>/dev/null || true
        for tool in /opt/mino-tools/*; do
            name=$(basename "$tool")
            target="$HOME/.local/bin/$name"
            # Only symlink if: doesn't exist, OR is already a symlink (refresh)
            # Never overwrite a real file (user override)
            if [ ! -e "$target" ] || [ -L "$target" ]; then
                ln -sf "$tool" "$target" 2>/dev/null || true
            fi
        done
    fi
}

# Per-step marker directory
STEP_DIR="$HOME/.mino-bootstrap.d"
mkdir -p "$STEP_DIR" 2>/dev/null || true

# Quiet mode suppresses all bootstrap output (detached/non-interactive)
if [ -n "$MINO_QUIET_BOOTSTRAP" ]; then
    INSTALL_REDIRECT="/dev/null"
else
    INSTALL_REDIRECT="/dev/stderr"
fi

# Log to stderr unless quiet mode is enabled
log() { [ -n "$MINO_QUIET_BOOTSTRAP" ] || echo "$@" >&2; }

# Check bootstrap state — skip skeleton if already done, but always run layer installs
ALREADY_BOOTSTRAPPED=false
if [ -f "$MARKER" ]; then
    ALREADY_BOOTSTRAPPED=true
    BOOTSTRAPPED_VERSION=$(head -1 "$MARKER" 2>/dev/null || echo "")
    if [ "$BOOTSTRAPPED_VERSION" != "$IMAGE_VERSION" ]; then
        echo "Home bootstrapped with $BOOTSTRAPPED_VERSION, current image is $IMAGE_VERSION." >&2
        echo "Run 'mino cache clear --home' to reset, or ignore this message." >&2
    fi
fi

if [ "$ALREADY_BOOTSTRAPPED" = false ]; then
    log "Bootstrapping home directory..."
fi

# --- Step: skeleton (copy dotfiles from /etc/skel/) ---
# Skip if already bootstrapped (image or volume has files from podman auto-copy)
if [ "$ALREADY_BOOTSTRAPPED" = false ] && [ ! -f "$STEP_DIR/skeleton" ]; then
    for item in .oh-my-zsh .nvm .claude .local .zshrc .zsh_history; do
        if [ ! -e "$HOME/$item" ] && [ -e "/etc/skel/$item" ]; then
            cp -a "/etc/skel/$item" "$HOME/$item" 2>/dev/null || true
        fi
    done
    mkdir -p "$HOME/.npm-global" 2>/dev/null || true
    # Ensure nvm node is available for npm config
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    npm config set prefix "$HOME/.npm-global" 2>/dev/null || true
    echo "$IMAGE_VERSION" > "$STEP_DIR/skeleton" 2>/dev/null || true
fi

# --- Step: CLI tools (symlink from /opt/mino-tools/) ---
refresh_tool_symlinks

# --- Step: layer installs (from MINO_LAYER_MANIFEST env var) ---
if [ -n "$MINO_LAYER_MANIFEST" ]; then
    # Ensure nvm is available for npm operations
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

    echo "$MINO_LAYER_MANIFEST" | jq -c '.[]' 2>/dev/null | while read -r layer; do
        name=$(echo "$layer" | jq -r '.name')
        runtime=$(echo "$layer" | jq -r '.runtime // empty')

        # Skip if already installed
        if [ -f "$STEP_DIR/layer-$name" ]; then
            continue
        fi

        log "Installing layer: $name..."

        layer_ok=true
        case "$runtime" in
            nvm)
                version=$(echo "$layer" | jq -r '.runtime_version // "22"')
                if ! nvm install "$version" > "$INSTALL_REDIRECT" 2>&1; then
                    echo "Failed to install Node.js $version via nvm for layer '$name'" >&2
                    layer_ok=false
                fi
                if [ "$layer_ok" = true ]; then
                    nvm alias default "$version" > "$INSTALL_REDIRECT" 2>&1 || true
                    # Install npm globals
                    echo "$layer" | jq -r '.npm_globals[]? // empty' | while read -r pkg; do
                        log "  npm install -g $pkg"
                        npm install -g "$pkg" > "$INSTALL_REDIRECT" 2>&1 || true
                    done
                fi
                ;;
            rustup)
                log "Layer '$name' requires network access for first-run install..."
                version=$(echo "$layer" | jq -r '.runtime_version // "stable"')
                if ! command -v rustup >/dev/null 2>&1; then
                    if ! curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
                        sh -s -- -y --default-toolchain "$version" > "$INSTALL_REDIRECT" 2>&1; then
                        echo "Failed to install rustup for layer '$name'" >&2
                        layer_ok=false
                    fi
                fi
                if [ "$layer_ok" = true ]; then
                    # shellcheck disable=SC1091
                    source "$HOME/.cargo/env" 2>/dev/null || true
                    # Install cargo tools via binstall
                    if ! command -v cargo-binstall >/dev/null 2>&1; then
                        curl -L --proto '=https' --tlsv1.2 -sSf \
                            https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | \
                            bash > "$INSTALL_REDIRECT" 2>&1 || true
                    fi
                    echo "$layer" | jq -r '.cargo_tools[]? // empty' | while read -r tool; do
                        log "  cargo binstall $tool"
                        cargo binstall -y "$tool" > "$INSTALL_REDIRECT" 2>&1 || true
                    done
                fi
                ;;
            uv)
                log "Layer '$name' requires network access for first-run install..."
                if ! command -v uv >/dev/null 2>&1; then
                    if ! curl -LsSf --proto '=https' --tlsv1.2 https://astral.sh/uv/install.sh | sh > "$INSTALL_REDIRECT" 2>&1; then
                        echo "Failed to install uv for layer '$name'" >&2
                        layer_ok=false
                    fi
                fi
                if [ "$layer_ok" = true ]; then
                    # Ensure uv is in PATH after install
                    export PATH="$HOME/.local/bin:$PATH"
                    echo "$layer" | jq -r '.uv_tools[]? // empty' | while read -r tool; do
                        log "  uv tool install $tool"
                        uv tool install "$tool" > "$INSTALL_REDIRECT" 2>&1 || true
                    done
                fi
                ;;
            "")
                # No runtime — skip
                ;;
            *)
                echo "Unknown runtime '$runtime' for layer '$name', skipping" >&2
                ;;
        esac

        if [ "$layer_ok" = true ]; then
            echo "$IMAGE_VERSION" > "$STEP_DIR/layer-$name" 2>/dev/null || true
        fi
    done
fi

# Top-level marker
echo "$IMAGE_VERSION" > "$MARKER" 2>/dev/null || true
log "Bootstrap complete."
